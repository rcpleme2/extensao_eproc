{
  "manifest_version": 3,
  "name": "Extensão Auxiliar eProc",
  "version": "2.0",
  "description": "Extensão para auxiliar no uso e extração de relatórios do eProc",
  "permissions": ["downloads", "activeTab", "scripting", "tabs", "sidePanel", "storage"],
  "host_permissions": ["*://*/eproc/*"],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Extensão eProc",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/eproc/controlador.php*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
