{
  "manifest_version": 3,
  "name": "Extensão Auxiliar eProc",
  "version": "1.2.0",
  "description": "Extensão para auxiliar no uso e extração de relatórios do eProc",
  "permissions": ["downloads", "activeTab", "scripting", "tabs", "sidePanel", "storage"],
  "host_permissions": ["https://eproc1g.tjpr.jus.br/eproc/*", "https://eproc1g.tre.tjpr.jus.br/eproc/*"],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Extensão eProc",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://eproc1g.tjpr.jus.br/eproc/controlador.php*",
        "https://eproc1g.tre.tjpr.jus.br/eproc/controlador.php*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/pdf.worker.min.js"],
      "matches": ["https://eproc1g.tjpr.jus.br/*", "https://eproc1g.tre.tjpr.jus.br/*"]
    }
  ]
}
